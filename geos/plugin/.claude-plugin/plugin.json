{
  "name": "repo3-plugin",
  "version": "0.2.0",
  "description": "GEOS-authoring plugin: geos-rag MCP + XML self-verification Stop hook.",
  "author": {
    "name": "Brian Liu"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "skills"
  ],
  "mcpServers": {
    "geos-rag": {
      "command": "uv",
      "args": [
        "run",
        "--script",
        "${CLAUDE_PLUGIN_ROOT}/scripts/geos_rag_mcp.py"
      ],
      "env": {
        "GEOS_VECTOR_DB_DIR": "/data/shared/geophysics_agent_data/data/vector_db"
      }
    }
  }
}
